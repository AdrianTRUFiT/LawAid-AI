import fs from 'fs';
import path from 'path';
import crypto from 'crypto';

const HB_ROOT = 'D:/DEV/AIVA/homebase';

const PATHS = {
  queue: path.join(HB_ROOT, 'EXECUTION_QUEUE'),
  executed: path.join(HB_ROOT, 'EXECUTED'),
  denied: path.join(HB_ROOT, 'EXECUTION_DENIED'),
  live: path.join(HB_ROOT, 'LIVE_RECORD'),
  index: path.join(HB_ROOT, 'INDEX')
};

function sha(value: string) {
  return crypto.createHash('sha256').update(value).digest('hex');
}

function ensureDirs() {
  for (const dir of Object.values(PATHS)) {
    fs.mkdirSync(dir, { recursive: true });
  }
}

function readQueue() {
  if (!fs.existsSync(PATHS.queue)) return [];
  return fs.readdirSync(PATHS.queue).filter(f => f.endsWith('.md')).sort();
}

function extract(content: string, key: string) {
  const regex = new RegExp(key + ':\\s*"([^"]+)"');
  const match = content.match(regex);
  return match ? match[1] : null;
}

function isExecutable(content: string) {
  const text = content.toLowerCase();

  const blocked = [
    'mutate doctrine',
    'authorize public release',
    'execute payment',
    'bypass human custody',
    'production change',
    'external publish'
  ];

  const hits = blocked.filter(m => text.includes(m));

  return {
    allowed: hits.length === 0,
    hits
  };
}

function executionClass(content: string) {
  const text = content.toLowerCase();

  if (text.includes('reference') || text.includes('doctrine')) {
    return 'REFERENCE_RECORD';
  }

  if (text.includes('kb update') || text.includes('intake')) {
    return 'KNOWLEDGE_RECORD';
  }

  return 'UNCLASSIFIED';
}

function writeManifest(records: any[]) {
  const jsonPath = path.join(PATHS.index, 'hb-sos-execution-manifest.json');
  const mdPath = path.join(PATHS.index, 'hb-sos-execution-manifest.md');

  const manifest = {
    manifestType: 'HB-SOS_EXECUTION_MANIFEST_V1',
    generatedAt: new Date().toISOString(),
    records
  };

  fs.writeFileSync(jsonPath, JSON.stringify(manifest, null, 2), 'utf8');

  const md = [
    '# HB-SOS Execution Manifest',
    '',
    'Generated: ' + manifest.generatedAt,
    '',
    '## Execution Results',
    '',
    records.length
      ? records.map(r => '- ' + r.execId + ' | ' + r.status + ' | ' + r.class + ' | ' + r.sourceFile).join('\n')
      : '- None',
    '',
    '## Execution Law',
    '',
    '- Execution does not mutate doctrine.',
    '- Execution does not authorize public release.',
    '- Execution does not perform financial actions.',
    '- Execution produces records, not uncontrolled actions.',
    '- Live System Record is the only recognized outcome.'
  ].join('\n');

  fs.writeFileSync(mdPath, md, 'utf8');

  return { jsonPath, mdPath };
}

export function runHomebaseExecutor() {
  ensureDirs();

  const files = readQueue();
  const records: any[] = [];

  for (const file of files) {
    const sourcePath = path.join(PATHS.queue, file);
    const content = fs.readFileSync(sourcePath, 'utf8');

    const execId = 'HBEXEC-' + sha(file + content).slice(0, 12);
    const allowed = isExecutable(content);
    const eClass = executionClass(content);

    if (!allowed.allowed) {
      const deniedPath = path.join(PATHS.denied, file.replace('.md', '__EXECUTION_DENIED_' + execId + '.md'));

      fs.writeFileSync(deniedPath, content, 'utf8');

      records.push({
        execId,
        sourceFile: file,
        status: 'DENIED',
        reason: 'BLOCKED_CONTENT',
        hits: allowed.hits,
        class: eClass
      });

      continue;
    }

    const executedPath = path.join(PATHS.executed, file.replace('.md', '__EXECUTED_' + execId + '.md'));
    const livePath = path.join(PATHS.live, file.replace('.md', '__LIVE_' + execId + '.md'));

    const packet = [
      '---',
      'live_record: "HB-SOS_LIVE_SYSTEM_RECORD_V1"',
      'execution_id: "' + execId + '"',
      'source_file: "' + file + '"',
      'execution_class: "' + eClass + '"',
      'status: "EXECUTED"',
      'authority: "HB_EXECUTOR"',
      'created_at: "' + new Date().toISOString() + '"',
      '---',
      '',
      '# Live System Record',
      '',
      'Execution Class: ' + eClass,
      '',
      'Status: EXECUTED',
      '',
      '---',
      '',
      content
    ].join('\n');

    fs.writeFileSync(executedPath, packet, 'utf8');
    fs.writeFileSync(livePath, packet, 'utf8');

    records.push({
      execId,
      sourceFile: file,
      status: 'EXECUTED',
      class: eClass,
      livePath: livePath.replace(/\\/g, '/')
    });
  }

  const manifest = writeManifest(records);

  return {
    status: 'HB-SOS_EXECUTOR_COMPLETE',
    evaluated: records.length,
    executed: records.filter(r => r.status === 'EXECUTED').length,
    denied: records.filter(r => r.status === 'DENIED').length,
    records,
    manifest
  };
}
